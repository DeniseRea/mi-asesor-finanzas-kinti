    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// 1. Obtenemos la salida en texto generada por el Agente de IA\nlet raw = $json.output ?? '';\nif (typeof raw !== 'string') raw = JSON.stringify(raw);\n\n// 2. Limpiamos las etiquetas de Markdown de forma segura usando hex \nraw = raw.trim().replace(/^\\x60{3}(json)?/i, '').replace(/\\x60{3}$/, '').trim();\n\nlet parsed;\ntry {\n  parsed = JSON.parse(raw);\n} catch (e) {\n  parsed = { accion: 'OTRO', datos: {}, respuesta_chat: 'No pude entender tu mensaje, ¿puedes reformularlo?' };\n}\n\n// 3. Recuperamos las variables de contexto\nconst usuario_id = $('Director de Tráfico').item.json.usuario_id;\nconst origen = $('Director de Tráfico').item.json.origen;\n\n// 4. Lógica de normalización\nlet movimientosArray = [];\nif (parsed.accion === 'CARGA_MASIVA') {\n  movimientosArray = Array.isArray(parsed.datos) ? parsed.datos : [];\n} else if (parsed.datos && typeof parsed.datos === 'object' && Object.keys(parsed.datos).length > 0) {\n  movimientosArray = [parsed.datos];\n}\n\nreturn {\n  json: {\n    usuario_id: usuario_id,\n    origen: origen,\n    accion: parsed.accion || 'OTRO',\n    movimientos: movimientosArray,\n    respuesta_chat: parsed.respuesta_chat || 'Operación procesada correctamente.'\n  }\n};"
      },
